    var start = ee.Date.fromYMD(year, doy_start_month, doy_start_day);
    var end = ee.Date.fromYMD(year, doy_end_day, doy_end_month);
    
        var composite = ee.ImageCollection('NASA/HLS/HLSL30/v002')
          .filterDate(start, end)
          .filterBounds(aoi)
          .map(maskHLS)
          .map(scaleHLS)            
          .select(['B2', 'B3', 'B4', 'B5', 'B6', 'B7'])
          .map(addIndices)
          .median()
          .clip(aoi)
          .set('year', year)
          .set('system:time_start', start.millis());

        var finalImage = addElevation(
          addNightTimeLight(composite, start, end)
          );
          
    return finalImage;
